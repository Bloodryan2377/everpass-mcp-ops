/* ============================================================
   EverPass Mobile Command Center — Result Surface
   ============================================================ */

.filter-row {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding: 4px 0 10px;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.filter-row::-webkit-scrollbar { display: none; }
.filter-chip {
  flex: none;
  padding: 8px 14px;
  border-radius: 999px;
  background: var(--c-bg-elev);
  border: 1px solid var(--c-border);
  color: var(--c-fg-mute);
  font-size: 13px;
  font-weight: 600;
  white-space: nowrap;
  min-height: 36px;
}
.filter-chip[aria-pressed='true'] {
  border-color: var(--c-accent);
  background: color-mix(in srgb, var(--c-accent) 14%, var(--c-bg-elev));
  color: var(--c-fg);
}

.results-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px; }
.result-item {
  background: var(--c-bg-elev);
  border: 1px solid var(--c-border);
  border-radius: var(--r-md);
  padding: 12px 14px;
}
.result-item .result-head {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  align-items: baseline;
  margin-bottom: 4px;
}
.result-item .result-title { font-weight: 700; font-size: 14px; line-height: 1.3; }
.result-item .result-kind {
  font-size: 11px;
  color: var(--c-accent);
  text-transform: uppercase;
  letter-spacing: 0.6px;
  white-space: nowrap;
}
.result-item .result-summary {
  font-size: 13px;
  color: var(--c-fg-mute);
  line-height: 1.45;
  margin-bottom: 6px;
}
.result-item .result-meta {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  font-size: 11px;
  color: var(--c-fg-faint);
}
.result-item .result-meta .pill {
  background: var(--c-bg-elev-2);
  padding: 2px 8px;
  border-radius: 999px;
}
.result-item .result-meta .pill.partner { color: var(--c-accent); }
.result-item .result-meta .pill.review { color: var(--c-warn); }
.result-item .result-meta .pill.confidence-high { color: var(--c-success); }
.result-item .result-meta .pill.confidence-low { color: var(--c-warn); }

.result-detail {
  background: var(--c-bg-elev);
  border: 1px solid var(--c-border);
  border-radius: var(--r-md);
  padding: 14px;
}
.result-detail .result-detail-meta {
  font-size: 12px;
  color: var(--c-fg-mute);
  margin-bottom: 10px;
}
.result-detail .filename {
  font-family: ui-monospace, monospace;
  font-size: 11px;
  color: var(--c-fg-faint);
  word-break: break-all;
  display: block;
  margin-top: 8px;
}
